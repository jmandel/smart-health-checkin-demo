{
  "name": "smart-health-checkin",
  "version": "0.1.0",
  "description": "Browser library for SMART Health Check-in protocol (OID4VP profile)",
  "type": "module",
  "main": "./dist/smart-health-checkin.js",
  "module": "./dist/smart-health-checkin.js",
  "types": "./dist/smart-health-checkin.d.ts",
  "exports": {
    ".": {
      "import": "./dist/smart-health-checkin.js",
      "types": "./dist/smart-health-checkin.d.ts"
    },
    "./browser": "./dist/smart-health-checkin.iife.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "serve": "STATIC_DIR=build/smart-health-checkin-demo bun demo/serve-demo.ts",
    "demo": "bun run build && bun run serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmandel/smart-health-checkin-demo.git"
  },
  "keywords": [
    "smart",
    "health",
    "fhir",
    "oid4vp",
    "verifiable-credentials"
  ],
  "license": "MIT",
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "jose": "^5.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "playwright": "^1.59.1",
    "typescript": "^5.0.0"
  }
}
